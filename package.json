{
  "name": "lapclip-f1-ui",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "F1-qualifying-style timing visualizer for LapClip individual time-trial results",
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.config.userscript.ts",
    "build:spa": "vite build",
    "build:bookmarklet": "vite build --config vite.config.bookmarklet.ts",
    "build:android-asset": "npm run build:bookmarklet && node -e \"require('fs').copyFileSync('dist/lapclip-bookmarklet.js','android/app/src/main/assets/lapclip-overlay.js')\"",
    "build:ios-shortcut": "npm run build:bookmarklet && node scripts/gen-ios-shortcut.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "express": "^4.21.2",
    "node-html-parser": "^7.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260524.1",
    "@tailwindcss/vite": "^4.0.9",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.13.5",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.0.9",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vite": "^6.2.0",
    "vite-plugin-monkey": "^7.1.9",
    "wrangler": "^4.94.0"
  }
}
